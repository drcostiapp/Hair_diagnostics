# ===========================================
# Dr. Costi AR Avatar - Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# HeyGen / Avatar Platform
HEYGEN_API_KEY=your_api_key_here
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
HEYGEN_KNOWLEDGE_BASE_ID=

# ElevenLabs (if using for voice instead of HeyGen)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Backend Server
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://drcosti:drcosti_dev@localhost:5432/dr_costi_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=generate_a_secure_secret_here
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# Encryption (for patient data at rest)
ENCRYPTION_KEY=generate_a_32_byte_hex_key_here

# AWS (Production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BUCKET_NAME=dr-costi-avatar-assets
S3_AUDIO_BUCKET=dr-costi-audio-recordings

# Third-Party Integrations
SKINPERFECTION_API_URL=https://skinperfection.world/api
SKINPERFECTION_API_KEY=
BOOKING_SYSTEM_API_URL=
BOOKING_SYSTEM_API_KEY=

# Twilio (WhatsApp notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Sentry (Error tracking)
SENTRY_DSN=

# Feature Flags
ENABLE_AR=true
ENABLE_ARABIC=false
ENABLE_ANALYTICS=true
ENABLE_PRODUCT_RECOMMENDATIONS=true
ENABLE_BOOKING_INTEGRATION=true

# Frontend (VITE_ prefix for client-side access)
VITE_API_BASE_URL=http://localhost:3001/api
VITE_HEYGEN_API_KEY=your_api_key_here
VITE_HEYGEN_AVATAR_ID=
VITE_HEYGEN_VOICE_ID=
VITE_ENABLE_AR=true
VITE_ENABLE_ARABIC=false
