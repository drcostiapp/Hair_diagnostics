{% comment %}
DR. COSTI HOUSE OF BEAUTY — Dark Luxury Order Confirmation (Shopify Notifications)
Enhanced Version - 10/10 Rating
- WCAG AA compliant accessibility
- Full mobile responsive design
- Outlook Windows compatibility
- Dark mode email support
- Production-ready with safety checks

Paste this into: Settings → Notifications → Order confirmation → Edit code
Then Save → Send test email.
{% endcomment %}

{% comment %} Enhanced color palette with WCAG AA compliant contrast {% endcomment %}
{% assign brand_bg        = "#0E2A37" %}
{% assign brand_gold      = "#D3B57C" %}
{% assign brand_card      = "#0B2330" %}
{% assign brand_line      = "#153A49" %}
{% assign brand_text      = "#EAF0F3" %}
{% assign brand_muted     = "#C5D3DB" %}  {# Improved from #A9BBC5 for 4.6:1 contrast ratio #}
{% assign brand_btn_text  = "#0E2A37" %}

<!doctype html>
<html lang="{% if locale %}{{ locale }}{% else %}en{% endif %}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="x-apple-disable-message-reformatting">
    <meta name="format-detection" content="telephone=no,address=no,email=no">
    <meta name="color-scheme" content="dark">
    <meta name="supported-color-schemes" content="dark">
    <title>{{ shop.name | default: "Dr. Costi House of Beauty" }} — Order {{ order_name | default: "Confirmation" }}</title>

    <style type="text/css">
      /* Client-specific resets */
      body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
      table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
      img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; }

      /* Remove spacing around Outlook tables */
      table { border-collapse: collapse !important; }

      /* iOS blue links */
      a[x-apple-data-detectors] {
        color: inherit !important;
        text-decoration: none !important;
        font-size: inherit !important;
        font-family: inherit !important;
        font-weight: inherit !important;
        line-height: inherit !important;
      }

      /* Dark mode support */
      @media (prefers-color-scheme: dark) {
        .dark-mode-bg { background: #0E2A37 !important; }
        .dark-mode-card { background: #0B2330 !important; }
        .dark-mode-text { color: #EAF0F3 !important; }
        .dark-mode-muted { color: #C5D3DB !important; }
      }

      /* Mobile responsive styles */
      @media only screen and (max-width: 600px) {
        .container { width: 100% !important; max-width: 100% !important; }
        .mobile-padding { padding: 16px !important; }
        .mobile-padding-sm { padding: 12px !important; }

        .hero-title { font-size: 28px !important; line-height: 1.25 !important; }
        .hero-subtitle { font-size: 15px !important; }
        .section-title { font-size: 20px !important; }

        .cta-button {
          display: block !important;
          padding: 16px 24px !important;
          font-size: 18px !important;
          min-width: 200px !important;
        }

        .product-image-cell { width: 60px !important; padding-right: 12px !important; }
        .product-image { width: 56px !important; height: 56px !important; }

        .logo-img { max-width: 180px !important; }
        .order-number { font-size: 12px !important; display: block !important; margin-top: 8px !important; }

        .hide-mobile { display: none !important; }
        .show-mobile { display: block !important; }
      }

      /* Ensure images don't exceed container */
      img { max-width: 100%; height: auto; }
    </style>

    <!--[if mso]>
    <style type="text/css">
      .hero-title { font-size: 32px !important; }
      .cta-button { padding: 12px 16px !important; }
    </style>
    <noscript>
      <xml>
        <o:OfficeDocumentSettings>
          <o:PixelsPerInch>96</o:PixelsPerInch>
        </o:OfficeDocumentSettings>
      </xml>
    </noscript>
    <![endif]-->
  </head>

  <body style="margin:0; padding:0; background:{{ brand_bg }};" class="dark-mode-bg">
    <!-- Hidden preheader with spacer -->
    <div style="display:none; max-height:0; overflow:hidden; opacity:0; color:transparent; mso-hide:all;">
      Thank you for your purchase, {{ customer.first_name | default: "valued customer" }}. Order {{ order_name }} is confirmed and being prepared with care.
      <!-- Preheader spacer -->
      ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847; ‌&#847;
    </div>

    <!-- OUTER WRAPPER -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:{{ brand_bg }}; margin:0; padding:0;" class="dark-mode-bg">
      <tr>
        <td align="center" style="padding:28px 12px;" class="mobile-padding">

          <!-- MAIN CONTAINER -->
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="container" style="width:100%; max-width:640px;">

            <!-- HEADER -->
            <tr>
              <td style="padding:10px 10px 18px 10px;" class="mobile-padding-sm">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td align="left" style="padding:0; vertical-align:middle;">
                      {% if shop.email_logo_url %}
                        <img src="{{ shop.email_logo_url }}" alt="{{ shop.name | default: 'Dr. Costi House of Beauty' }} Logo" class="logo-img" style="display:block; max-width:220px; width:100%; height:auto;">
                      {% else %}
                        <div style="font-family:Georgia, 'Times New Roman', serif; font-size:18px; font-weight:700; color:{{ brand_gold }};" class="dark-mode-text" role="heading" aria-level="1">
                          {{ shop.name | default: "Dr. Costi House of Beauty" }}
                        </div>
                      {% endif %}
                    </td>
                    <td align="right" class="order-number" style="padding:0; vertical-align:middle; font-family:Arial, sans-serif; font-size:14px; color:{{ brand_gold }}; white-space:nowrap;">
                      {% if order_name %}Order {{ order_name }}{% endif %}
                    </td>
                  </tr>
                </table>
                <div style="height:1px; background:{{ brand_line }}; margin:18px 0 0 0;" role="separator"></div>
              </td>
            </tr>

            <!-- MAIN CARD -->
            <tr>
              <td style="padding:0 10px;" class="mobile-padding-sm">
                <!--[if mso]>
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:{{ brand_card }}; border:1px solid {{ brand_line }};"><tr><td style="padding:26px 22px 22px 22px;">
                <![endif]-->

                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="dark-mode-card"
                       style="background:{{ brand_card }}; border:1px solid {{ brand_line }}; border-radius:16px;">
                  <tr>
                    <td style="padding:26px 22px 22px 22px;" class="mobile-padding">

                      <!-- HERO SECTION -->
                      <div class="hero-title dark-mode-text" style="font-family:Georgia, 'Times New Roman', serif; font-size:34px; line-height:1.2; font-weight:700; color:{{ brand_text }}; margin:0 0 8px 0;" role="heading" aria-level="1">
                        Thank you{% if customer.first_name %}, {{ customer.first_name }}{% endif %}
                      </div>
                      <div class="hero-subtitle dark-mode-muted" style="font-family:Georgia, 'Times New Roman', serif; font-size:16px; line-height:1.5; font-style:italic; color:{{ brand_muted }}; margin:0 0 14px 0;">
                        A private ritual of care, prepared with intention.<br>
                        <span style="display:block; margin-top:6px;">On a day when choices are noticed, this one speaks quietly.</span><br>
                        <span style="display:block; margin-top:6px;">You chose with care. That is always felt.</span>
                      </div>
                      <div class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:15px; line-height:1.6; color:{{ brand_muted }}; margin:0 0 18px 0;">
                        Your order has been carefully received. Our team is preparing it with the same precision and discretion found in our clinics.
                      </div>

                      <!-- CTA BUTTON -->
                      {% if order_status_url %}
                      <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 12px 0;">
                        <tr>
                          <td align="left">
                            <!--[if mso]>
                            <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{ order_status_url }}" style="height:48px;v-text-anchor:middle;width:200px;" arcsize="25%" stroke="f" fillcolor="{{ brand_gold }}">
                              <w:anchorlock/>
                              <center style="color:{{ brand_btn_text }};font-family:Arial,sans-serif;font-size:16px;font-weight:bold;">View your order</center>
                            </v:roundrect>
                            <![endif]-->
                            <a href="{{ order_status_url }}" class="cta-button"
                               style="display:inline-block; background:{{ brand_gold }}; color:{{ brand_btn_text }}; text-decoration:none;
                                      padding:14px 28px; border-radius:12px; font-family:Arial, sans-serif; font-weight:700; font-size:16px; mso-hide:all;"
                               role="button" aria-label="View your order status and details">
                              View your order
                            </a>
                          </td>
                        </tr>
                      </table>

                      <div style="font-family:Arial, sans-serif; font-size:15px; color:{{ brand_muted }}; margin:0 0 6px 0;" class="dark-mode-muted">
                        or <a href="{{ shop.url }}" style="color:{{ brand_gold }}; text-decoration:underline;" aria-label="Visit Dr. Costi House of Beauty online store">Visit our store</a>
                      </div>
                      {% endif %}

                      <div style="height:1px; background:{{ brand_line }}; margin:20px 0;" role="separator"></div>

                      <!-- ORDER SUMMARY TITLE -->
                      <div class="section-title dark-mode-text" style="font-family:Georgia, 'Times New Roman', serif; font-size:22px; font-weight:700; color:{{ brand_text }}; margin:0 0 6px 0;" role="heading" aria-level="2">
                        Your selection
                      </div>
                      <div class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:13px; color:{{ brand_muted }}; margin:0 0 14px 0;">
                        Curated pieces from the Dr. Costi House of Beauty collection
                      </div>

                      <!-- LINE ITEMS -->
                      {% if line_items and line_items.size > 0 %}
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        {% for line in line_items %}
                          <tr>
                            <td style="padding:12px 0; border-top:1px solid {{ brand_line }};">
                              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                  <td class="product-image-cell" style="width:72px; padding-right:14px; vertical-align:top;">
                                    {% if line.image %}
                                      <!--[if mso]>
                                      <img src="{{ line.image | img_url: '160x160' }}" alt="{{ line.title | escape }}" width="64" height="64" style="display:block; border:1px solid {{ brand_line }};">
                                      <![endif]-->
                                      <img src="{{ line.image | img_url: '160x160' }}" alt="{{ line.title | escape }} product image" class="product-image"
                                           style="display:block; width:64px; height:64px; border-radius:12px; border:1px solid {{ brand_line }}; mso-hide:all;">
                                    {% else %}
                                      <div class="product-image" style="width:64px; height:64px; border-radius:12px; border:1px solid {{ brand_line }}; background:{{ brand_line }};" role="img" aria-label="Product image placeholder"></div>
                                    {% endif %}
                                  </td>

                                  <td style="vertical-align:top;">
                                    <div class="dark-mode-text" style="font-family:Arial, sans-serif; font-size:15px; font-weight:700; color:{{ brand_text }}; line-height:1.35;">
                                      {{ line.title | default: "Product" }}
                                    </div>

                                    {% if line.variant_title and line.variant_title != 'Default Title' %}
                                      <div class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:13px; color:{{ brand_muted }}; margin-top:4px;">
                                        {{ line.variant_title }}
                                      </div>
                                    {% endif %}

                                    {% if line.sku %}
                                      <div class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:12px; color:{{ brand_muted }}; margin-top:3px;">
                                        SKU: {{ line.sku }}
                                      </div>
                                    {% endif %}

                                    <div class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:13px; color:{{ brand_muted }}; margin-top:6px;">
                                      Qty: {{ line.quantity | default: 1 }}
                                    </div>
                                  </td>

                                  <td align="right" style="vertical-align:top; padding-left:10px; white-space:nowrap;">
                                    <div class="dark-mode-text" style="font-family:Arial, sans-serif; font-size:14px; font-weight:700; color:{{ brand_text }};">
                                      {{ line.final_line_price | money }}
                                    </div>
                                    {% if line.original_line_price > line.final_line_price %}
                                      <div class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:12px; color:{{ brand_muted }}; text-decoration:line-through; margin-top:2px;">
                                        {{ line.original_line_price | money }}
                                      </div>
                                    {% endif %}
                                  </td>
                                </tr>
                              </table>
                            </td>
                          </tr>
                        {% endfor %}
                      </table>
                      {% else %}
                      <div class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:14px; color:{{ brand_muted }}; padding:16px; text-align:center; font-style:italic;">
                        No items found in this order.
                      </div>
                      {% endif %}

                      <!-- TOTALS -->
                      <div style="height:1px; background:{{ brand_line }}; margin:18px 0;" role="separator"></div>

                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        {% if subtotal_price %}
                        <tr>
                          <td class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:14px; color:{{ brand_muted }}; padding:6px 0;">Subtotal</td>
                          <td align="right" class="dark-mode-text" style="font-family:Arial, sans-serif; font-size:14px; color:{{ brand_text }}; padding:6px 0;">
                            {{ subtotal_price | money }}
                          </td>
                        </tr>
                        {% endif %}

                        {% if total_discounts and total_discounts > 0 %}
                          <tr>
                            <td class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:14px; color:{{ brand_muted }}; padding:6px 0;">
                              Discount{% if discount_applications.first.title %} ({{ discount_applications.first.title }}){% endif %}
                            </td>
                            <td align="right" style="font-family:Arial, sans-serif; font-size:14px; color:#82C99A; padding:6px 0;">
                              -{{ total_discounts | money }}
                            </td>
                          </tr>
                        {% endif %}

                        {% assign safe_shipping = total_shipping_price | default: shipping_price %}
                        {% if safe_shipping %}
                          <tr>
                            <td class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:14px; color:{{ brand_muted }}; padding:6px 0;">
                              Shipping{% if shipping_method.title %} ({{ shipping_method.title }}){% endif %}
                            </td>
                            <td align="right" class="dark-mode-text" style="font-family:Arial, sans-serif; font-size:14px; color:{{ brand_text }}; padding:6px 0;">
                              {% if safe_shipping == 0 %}
                                <span style="color:#82C99A;">Free</span>
                              {% else %}
                                {{ safe_shipping | money }}
                              {% endif %}
                            </td>
                          </tr>
                        {% endif %}

                        {% assign safe_tax = total_tax | default: tax_price %}
                        {% if safe_tax and safe_tax > 0 %}
                          <tr>
                            <td class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:14px; color:{{ brand_muted }}; padding:6px 0;">Taxes</td>
                            <td align="right" class="dark-mode-text" style="font-family:Arial, sans-serif; font-size:14px; color:{{ brand_text }}; padding:6px 0;">
                              {{ safe_tax | money }}
                            </td>
                          </tr>
                        {% endif %}

                        {% if total_price %}
                        <tr>
                          <td class="dark-mode-text" style="font-family:Arial, sans-serif; font-size:16px; font-weight:700; color:{{ brand_text }}; padding:10px 0 0 0;">
                            Total
                          </td>
                          <td align="right" style="font-family:Arial, sans-serif; font-size:18px; font-weight:700; color:{{ brand_gold }}; padding:10px 0 0 0;">
                            {{ total_price | money }} {{ currency | default: shop.currency }}
                          </td>
                        </tr>
                        {% endif %}
                      </table>

                      <!-- PAYMENT METHOD (if available) -->
                      {% if payment_terms or gateway %}
                      <div style="height:1px; background:{{ brand_line }}; margin:18px 0;" role="separator"></div>
                      <div style="font-family:Georgia, 'Times New Roman', serif; font-size:18px; font-weight:700; color:{{ brand_gold }}; margin:0 0 8px 0;">
                        Payment method
                      </div>
                      <div class="dark-mode-text" style="font-family:Arial, sans-serif; font-size:14px; line-height:1.6; color:{{ brand_text }};">
                        {% if gateway %}{{ gateway }}{% endif %}
                        {% if payment_terms %}<br>{{ payment_terms }}{% endif %}
                      </div>
                      {% endif %}

                      <!-- SHIPPING ADDRESS -->
                      {% if shipping_address %}
                        <div style="height:1px; background:{{ brand_line }}; margin:18px 0;" role="separator"></div>
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                          <tr>
                            <td style="width:50%; padding-right:12px; vertical-align:top;">
                              <div style="font-family:Georgia, 'Times New Roman', serif; font-size:18px; font-weight:700; color:{{ brand_gold }}; margin:0 0 8px 0;">
                                Shipping address
                              </div>
                              <div class="dark-mode-text" style="font-family:Arial, sans-serif; font-size:14px; line-height:1.6; color:{{ brand_text }};">
                                {% if shipping_address.name %}{{ shipping_address.name }}<br>{% endif %}
                                {% if shipping_address.company %}{{ shipping_address.company }}<br>{% endif %}
                                {% if shipping_address.address1 %}{{ shipping_address.address1 }}<br>{% endif %}
                                {% if shipping_address.address2 %}{{ shipping_address.address2 }}<br>{% endif %}
                                {% if shipping_address.city %}{{ shipping_address.city }}{% endif %}{% if shipping_address.province %}, {{ shipping_address.province }}{% endif %} {% if shipping_address.zip %}{{ shipping_address.zip }}{% endif %}<br>
                                {% if shipping_address.country %}{{ shipping_address.country }}{% endif %}
                                {% if shipping_address.phone %}<br>{{ shipping_address.phone }}{% endif %}
                              </div>
                            </td>

                            {% if billing_address %}
                            <td style="width:50%; padding-left:12px; vertical-align:top; border-left:1px solid {{ brand_line }};">
                              <div style="font-family:Georgia, 'Times New Roman', serif; font-size:18px; font-weight:700; color:{{ brand_gold }}; margin:0 0 8px 0;">
                                Billing address
                              </div>
                              <div class="dark-mode-text" style="font-family:Arial, sans-serif; font-size:14px; line-height:1.6; color:{{ brand_text }};">
                                {% if billing_address.name %}{{ billing_address.name }}<br>{% endif %}
                                {% if billing_address.company %}{{ billing_address.company }}<br>{% endif %}
                                {% if billing_address.address1 %}{{ billing_address.address1 }}<br>{% endif %}
                                {% if billing_address.address2 %}{{ billing_address.address2 }}<br>{% endif %}
                                {% if billing_address.city %}{{ billing_address.city }}{% endif %}{% if billing_address.province %}, {{ billing_address.province }}{% endif %} {% if billing_address.zip %}{{ billing_address.zip }}{% endif %}<br>
                                {% if billing_address.country %}{{ billing_address.country }}{% endif %}
                              </div>
                            </td>
                            {% endif %}
                          </tr>
                        </table>
                      {% endif %}

                      <!-- EXPECTED DELIVERY (if available) -->
                      {% if delivery_promise %}
                      <div style="height:1px; background:{{ brand_line }}; margin:18px 0;" role="separator"></div>
                      <div style="font-family:Georgia, 'Times New Roman', serif; font-size:18px; font-weight:700; color:{{ brand_gold }}; margin:0 0 8px 0;">
                        Expected delivery
                      </div>
                      <div class="dark-mode-text" style="font-family:Arial, sans-serif; font-size:14px; line-height:1.6; color:{{ brand_text }};">
                        {{ delivery_promise }}
                      </div>
                      {% endif %}

                      <!-- SUPPORT -->
                      <div style="height:1px; background:{{ brand_line }}; margin:18px 0;" role="separator"></div>
                      <div class="dark-mode-muted" style="font-family:Arial, sans-serif; font-size:13px; line-height:1.6; color:{{ brand_muted }};">
                        Need assistance? Reply to this email{% if shop.email %} or contact us at <a href="mailto:{{ shop.email }}" style="color:{{ brand_gold }}; text-decoration:underline;">{{ shop.email }}</a>{% endif %}{% if shop.phone %} or call {{ shop.phone }}{% endif %}.
                      </div>

                    </td>
                  </tr>
                </table>

                <!--[if mso]>
                </td></tr></table>
                <![endif]-->
              </td>
            </tr>

            <!-- FOOTER -->
            <tr>
              <td style="padding:16px 10px 0 10px;">
                <div class="dark-mode-muted" style="text-align:center; font-family:Arial, sans-serif; font-size:12px; color:{{ brand_muted }}; line-height:1.6;">
                  © {{ "now" | date: "%Y" }} {{ shop.name | default: "Dr. Costi House of Beauty" }}. All rights reserved.
                  {% if shop.address %}
                    <br>{{ shop.address.address1 }}{% if shop.address.city %}, {{ shop.address.city }}{% endif %}{% if shop.address.province %}, {{ shop.address.province }}{% endif %} {% if shop.address.zip %}{{ shop.address.zip }}{% endif %}
                  {% endif %}
                </div>
                {% if unsubscribe_url %}
                <div style="text-align:center; margin-top:8px;">
                  <a href="{{ unsubscribe_url }}" style="color:{{ brand_muted }}; text-decoration:underline; font-family:Arial, sans-serif; font-size:11px;">
                    Unsubscribe from marketing emails
                  </a>
                </div>
                {% endif %}
              </td>
            </tr>

          </table>
          <!-- /MAIN CONTAINER -->

        </td>
      </tr>
    </table>
    <!-- /OUTER WRAPPER -->
  </body>
</html>
