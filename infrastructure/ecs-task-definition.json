{
  "family": "dr-costi-avatar",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "ACCOUNT_ID.dkr.ecr.eu-west-1.amazonaws.com/dr-costi-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3001" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:eu-west-1:ACCOUNT_ID:secret:dr-costi/database-url" },
        { "name": "REDIS_URL", "valueFrom": "arn:aws:secretsmanager:eu-west-1:ACCOUNT_ID:secret:dr-costi/redis-url" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:secretsmanager:eu-west-1:ACCOUNT_ID:secret:dr-costi/jwt-secret" },
        { "name": "HEYGEN_API_KEY", "valueFrom": "arn:aws:secretsmanager:eu-west-1:ACCOUNT_ID:secret:dr-costi/heygen-api-key" },
        { "name": "ENCRYPTION_KEY", "valueFrom": "arn:aws:secretsmanager:eu-west-1:ACCOUNT_ID:secret:dr-costi/encryption-key" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/dr-costi-avatar",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "api"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3001/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
